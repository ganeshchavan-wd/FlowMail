{
	"appId": "com.flowmail.app",
	"appName": "FlowMail AI",
	"webDir": "out",
	"server": {
		"url": "https://flow-mail-phi.vercel.app/",
		"cleartext": false,
		"androidScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#0a0a0a",
